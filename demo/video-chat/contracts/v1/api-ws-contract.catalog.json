{
  "catalog_version": "v1.0.7-beta",
  "catalog_name": "king-video-chat-api-ws",
  "api": {
    "runtime_health": {
      "type": "object",
      "required": {
        "service": { "type": "string", "enum": ["video-chat-backend-king-php"] },
        "status": { "type": "string", "enum": ["ok"] },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      },
      "allow_additional": false
    },
    "runtime_admin_detail": {
      "type": "object",
      "required": {
        "service": { "type": "string", "enum": ["video-chat-backend-king-php"] },
        "app": {
          "type": "object",
          "required": {
            "name": { "type": "string", "enum": ["king-video-chat-backend"] },
            "version": { "type": "string", "min_length": 1 },
            "environment": { "type": "string", "min_length": 1 }
          }
        },
        "runtime": {
          "type": "object",
          "required": {
            "king_version": { "type": "string", "min_length": 1 },
            "transport": { "type": "string", "enum": ["king_http1_server_listen_once"] },
            "ws_path": { "type": "string", "pattern": "/^\\//" },
            "health": {
              "type": "object",
              "required": {
                "module_status": { "type": "string", "min_length": 1 },
                "system_status": { "type": "string", "min_length": 1 },
                "build": { "one_of": [{ "type": "string", "min_length": 1 }, { "type": "null" }] },
                "module_version": { "one_of": [{ "type": "string", "min_length": 1 }, { "type": "null" }] },
                "active_runtime_count": { "type": "int", "min": 0 }
              }
            }
          }
        },
        "database": {
          "type": "object",
          "required": {
            "path": { "type": "string", "min_length": 1 },
            "schema_version": { "type": "int", "min": 0 },
            "migrations_total": { "type": "int", "min": 0 },
            "migrations_applied": { "type": "int", "min": 0 },
            "demo_users": {
              "type": "array",
              "items": {
                "type": "object",
                "required": {
                  "email": { "type": "string", "pattern": "/@/" },
                  "display_name": { "type": "string", "min_length": 1 },
                  "role": { "type": "string", "enum": ["admin", "moderator", "user"] }
                }
              }
            }
          }
        },
        "auth": {
          "type": "object",
          "required": {
            "login_endpoint": { "type": "string", "enum": ["/api/auth/login"] },
            "session_endpoint": { "type": "string", "enum": ["/api/auth/session"] },
            "refresh_endpoint": { "type": "string", "enum": ["/api/auth/refresh"] },
            "logout_endpoint": { "type": "string", "enum": ["/api/auth/logout"] },
            "settings_endpoint": { "type": "string", "enum": ["/api/user/settings"] },
            "avatar_upload_endpoint": { "type": "string", "enum": ["/api/user/avatar"] }
          }
        },
        "calls": {
          "type": "object",
          "required": {
            "list_endpoint": { "type": "string", "enum": ["/api/calls"] },
            "invite_code_create_endpoint": { "type": "string", "enum": ["/api/invite-codes"] },
            "invite_code_copy_endpoint_template": { "type": "string", "enum": ["/api/invite-codes/{id}/copy"] },
            "invite_code_redeem_endpoint": { "type": "string", "enum": ["/api/invite-codes/redeem"] }
          }
        },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" },
        "status": { "type": "string", "enum": ["ok"] }
      }
    },
    "bootstrap": {
      "type": "object",
      "required": {
        "service": { "type": "string", "enum": ["video-chat-backend-king-php"] },
        "status": { "type": "string", "enum": ["bootstrapped"] },
        "message": { "type": "string", "min_length": 1 },
        "ws_path": { "type": "string", "pattern": "/^\\//" },
        "runtime_endpoint": { "type": "string", "enum": ["/api/runtime"] },
        "version_endpoint": { "type": "string", "enum": ["/api/version"] },
        "admin_runtime_endpoint": { "type": "string", "enum": ["/api/admin/runtime"] },
        "calls_endpoint": { "type": "string", "enum": ["/api/calls"] },
        "call_create_endpoint": { "type": "string", "enum": ["/api/calls"] },
        "call_update_endpoint_template": { "type": "string", "enum": ["/api/calls/{id}"] },
        "call_cancel_endpoint_template": { "type": "string", "enum": ["/api/calls/{id}/cancel"] },
        "invite_code_create_endpoint": { "type": "string", "enum": ["/api/invite-codes"] },
        "invite_code_copy_endpoint_template": { "type": "string", "enum": ["/api/invite-codes/{id}/copy"] },
        "invite_code_redeem_endpoint": { "type": "string", "enum": ["/api/invite-codes/redeem"] },
        "login_endpoint": { "type": "string", "enum": ["/api/auth/login"] },
        "session_endpoint": { "type": "string", "enum": ["/api/auth/session"] },
        "refresh_endpoint": { "type": "string", "enum": ["/api/auth/refresh"] },
        "logout_endpoint": { "type": "string", "enum": ["/api/auth/logout"] },
        "admin_users_endpoint": { "type": "string", "enum": ["/api/admin/users"] },
        "admin_user_reactivate_endpoint_template": { "type": "string", "enum": ["/api/admin/users/{id}/reactivate"] },
        "user_settings_endpoint": { "type": "string", "enum": ["/api/user/settings"] },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      }
    },
    "error_response": {
      "type": "object",
      "required": {
        "status": { "type": "string", "enum": ["error"] },
        "error": {
          "type": "object",
          "required": {
            "code": { "type": "string", "min_length": 1 },
            "message": { "type": "string", "min_length": 1 }
          },
          "optional": {
            "details": { "type": "any" }
          }
        },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      }
    }
  },
  "ws": {
    "system_error": {
      "type": "object",
      "required": {
        "type": { "type": "string", "enum": ["system/error"] },
        "status": { "type": "string", "enum": ["error"] },
        "code": { "type": "string", "min_length": 1 },
        "message": { "type": "string", "min_length": 1 },
        "error": {
          "type": "object",
          "required": {
            "code": { "type": "string", "min_length": 1 },
            "message": { "type": "string", "min_length": 1 }
          },
          "optional": {
            "details": { "type": "any" }
          }
        },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      },
      "optional": {
        "details": { "type": "any" }
      }
    },
    "room_snapshot": {
      "type": "object",
      "required": {
        "type": { "type": "string", "enum": ["room/snapshot"] },
        "room_id": { "type": "string", "min_length": 1 },
        "participants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": {
              "connection_id": { "type": "string", "min_length": 1 },
              "room_id": { "type": "string", "min_length": 1 },
              "user": {
                "type": "object",
                "required": {
                  "id": { "type": "int", "min": 1 },
                  "display_name": { "type": "string", "min_length": 1 },
                  "role": { "type": "string", "enum": ["admin", "moderator", "user"] }
                }
              },
              "connected_at": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
            }
          }
        },
        "participant_count": { "type": "int", "min": 0 },
        "reason": { "type": "string", "min_length": 1 },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      }
    },
    "chat_message": {
      "type": "object",
      "required": {
        "type": { "type": "string", "enum": ["chat/message"] },
        "room_id": { "type": "string", "min_length": 1 },
        "message": {
          "type": "object",
          "required": {
            "id": { "type": "string", "pattern": "/^chat_/" },
            "client_message_id": { "one_of": [{ "type": "string", "min_length": 1 }, { "type": "null" }] },
            "text": { "type": "string", "min_length": 0 },
            "attachments": {
              "type": "array",
              "items": {
                "type": "object",
                "required": {
                  "id": { "type": "string", "min_length": 1 },
                  "name": { "type": "string", "min_length": 1 },
                  "content_type": { "type": "string", "min_length": 1 },
                  "size_bytes": { "type": "int", "min": 1 },
                  "kind": { "type": "string", "enum": ["image", "text", "pdf", "document"] },
                  "extension": { "type": "string", "min_length": 1 },
                  "download_url": { "type": "string", "pattern": "/^\\/api\\/calls\\//" }
                }
              }
            },
            "sender": {
              "type": "object",
              "required": {
                "user_id": { "type": "int", "min": 1 },
                "display_name": { "type": "string", "min_length": 1 },
                "role": { "type": "string", "enum": ["admin", "moderator", "user"] }
              }
            },
            "server_unix_ms": { "type": "int", "min": 1 },
            "server_time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
          }
        },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      }
    },
    "chat_ack": {
      "type": "object",
      "required": {
        "type": { "type": "string", "enum": ["chat/ack"] },
        "room_id": { "type": "string", "min_length": 1 },
        "ack_id": { "type": "string", "pattern": "/^chat_ack_/" },
        "message_id": { "type": "string", "pattern": "/^chat_/" },
        "client_message_id": { "one_of": [{ "type": "string", "min_length": 1 }, { "type": "null" }] },
        "server_time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" },
        "sent_count": { "type": "int", "min": 0 },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      }
    },
    "typing_start": {
      "type": "object",
      "required": {
        "type": { "type": "string", "enum": ["typing/start"] },
        "room_id": { "type": "string", "min_length": 1 },
        "participant": {
          "type": "object",
          "required": {
            "user_id": { "type": "int", "min": 1 },
            "display_name": { "type": "string", "min_length": 1 },
            "role": { "type": "string", "enum": ["admin", "moderator", "user"] }
          }
        },
        "expires_in_ms": { "type": "int", "min": 500 },
        "server_unix_ms": { "type": "int", "min": 1 },
        "server_time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      }
    },
    "typing_stop": {
      "type": "object",
      "required": {
        "type": { "type": "string", "enum": ["typing/stop"] },
        "room_id": { "type": "string", "min_length": 1 },
        "participant": {
          "type": "object",
          "required": {
            "user_id": { "type": "int", "min": 1 },
            "display_name": { "type": "string", "min_length": 1 },
            "role": { "type": "string", "enum": ["admin", "moderator", "user"] }
          }
        },
        "reason": { "type": "string", "min_length": 1 },
        "server_unix_ms": { "type": "int", "min": 1 },
        "server_time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      }
    },
    "reaction_event": {
      "type": "object",
      "required": {
        "type": { "type": "string", "enum": ["reaction/event"] },
        "room_id": { "type": "string", "min_length": 1 },
        "sender": {
          "type": "object",
          "required": {
            "user_id": { "type": "int", "min": 1 },
            "display_name": { "type": "string", "min_length": 1 },
            "role": { "type": "string", "enum": ["admin", "moderator", "user"] }
          }
        },
        "reaction": {
          "type": "object",
          "required": {
            "id": { "type": "string", "pattern": "/^reaction_/" },
            "emoji": { "type": "string", "min_length": 1 },
            "client_reaction_id": { "one_of": [{ "type": "string", "min_length": 1 }, { "type": "null" }] },
            "server_unix_ms": { "type": "int", "min": 1 },
            "server_time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
          }
        },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      }
    },
    "reaction_batch": {
      "type": "object",
      "required": {
        "type": { "type": "string", "enum": ["reaction/batch"] },
        "room_id": { "type": "string", "min_length": 1 },
        "sender": {
          "type": "object",
          "required": {
            "user_id": { "type": "int", "min": 1 },
            "display_name": { "type": "string", "min_length": 1 },
            "role": { "type": "string", "enum": ["admin", "moderator", "user"] }
          }
        },
        "batch": {
          "type": "object",
          "required": {
            "id": { "type": "string", "pattern": "/^reaction_batch_/" },
            "mode": { "type": "string", "min_length": 1 },
            "size": { "type": "int", "min": 1 },
            "server_unix_ms": { "type": "int", "min": 1 },
            "server_time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
          }
        },
        "reactions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": {
              "id": { "type": "string", "pattern": "/^reaction_/" },
              "emoji": { "type": "string", "min_length": 1 },
              "client_reaction_id": { "one_of": [{ "type": "string", "min_length": 1 }, { "type": "null" }] },
              "server_unix_ms": { "type": "int", "min": 1 },
              "server_time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
            }
          }
        },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      }
    },
    "lobby_snapshot": {
      "type": "object",
      "required": {
        "type": { "type": "string", "enum": ["lobby/snapshot"] },
        "room_id": { "type": "string", "min_length": 1 },
        "queue": {
          "type": "array",
          "items": {
            "type": "object",
            "required": {
              "user_id": { "type": "int", "min": 1 },
              "display_name": { "type": "string", "min_length": 1 },
              "role": { "type": "string", "enum": ["admin", "moderator", "user"] },
              "requested_unix_ms": { "type": "int", "min": 1 },
              "requested_at": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
            }
          }
        },
        "queue_count": { "type": "int", "min": 0 },
        "admitted": {
          "type": "array",
          "items": {
            "type": "object",
            "required": {
              "user_id": { "type": "int", "min": 1 },
              "display_name": { "type": "string", "min_length": 1 },
              "role": { "type": "string", "enum": ["admin", "moderator", "user"] },
              "admitted_unix_ms": { "type": "int", "min": 1 },
              "admitted_at": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
            }
          }
        },
        "admitted_count": { "type": "int", "min": 0 },
        "reason": { "type": "string", "min_length": 1 },
        "server_unix_ms": { "type": "int", "min": 1 },
        "server_time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      }
    },
    "signaling_event": {
      "type": "object",
      "required": {
        "type": { "type": "string", "enum": ["call/offer", "call/answer", "call/ice", "call/hangup", "media-security/hello", "media-security/sender-key"] },
        "room_id": { "type": "string", "min_length": 1 },
        "target_user_id": { "type": "int", "min": 1 },
        "sender": {
          "type": "object",
          "required": {
            "user_id": { "type": "int", "min": 1 },
            "display_name": { "type": "string", "min_length": 1 },
            "role": { "type": "string", "enum": ["admin", "moderator", "user"] }
          }
        },
        "payload": { "type": "any" },
        "signal": {
          "type": "object",
          "required": {
            "id": { "type": "string", "pattern": "/^signal_/" },
            "server_unix_ms": { "type": "int", "min": 1 },
            "server_time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
          }
        },
        "time": { "type": "string", "pattern": "/^\\d{4}-\\d{2}-\\d{2}T/" }
      }
    }
  }
}
