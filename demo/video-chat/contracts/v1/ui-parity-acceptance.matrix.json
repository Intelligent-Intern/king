{
  "matrix_version": "v1.0.7-beta",
  "matrix_name": "king-video-chat-ui-parity",
  "release_policy": {
    "mode": "tracked_gaps_block_release",
    "strict_env": "VIDEOCHAT_UI_PARITY_REQUIRE_COVERED",
    "tracker": "READYNESS_TRACKER.md",
    "notes": "Default validation proves the matrix and executable bindings. Strict release validation must fail while release_blocking gaps remain."
  },
  "release_gate": {
    "script": "test:e2e:release-gate",
    "command": "npm run test:e2e:release-gate",
    "required_ui_parity_specs": [
      "frontend-vue/tests/e2e/auth-navigation.spec.js",
      "frontend-vue/tests/e2e/login-backend-contract.spec.js",
      "frontend-vue/tests/e2e/ui-parity-journeys.spec.js",
      "frontend-vue/tests/e2e/responsive-call-management.spec.js",
      "frontend-vue/tests/e2e/shared-ui-surfaces.spec.js",
      "frontend-vue/tests/e2e/lobby-admission.spec.js",
      "frontend-vue/tests/e2e/chat-attachments.spec.js",
      "frontend-vue/tests/e2e/chat-archive.spec.js",
      "frontend-vue/tests/e2e/chat-activity-matrix.spec.js",
      "frontend-vue/tests/e2e/call-layout-strategies.spec.js"
    ],
    "required_core_video_journeys": [
      {
        "id": "owner_invite_lobby_admission_media_roster",
        "path": "frontend-vue/tests/e2e/lobby-admission.spec.js",
        "test_title": "admin creates/invites and admits user from lobby, both browsers share roster and media signals"
      },
      {
        "id": "chat_text_emoji_badge_attachment_archive",
        "path": "frontend-vue/tests/e2e/chat-activity-matrix.spec.js",
        "test_title": "chat journey covers text, emoji, unread badge, attachment, and read-only archive"
      },
      {
        "id": "mobile_call_create_edit_internal_participants",
        "path": "frontend-vue/tests/e2e/responsive-call-management.spec.js",
        "test_title": "mobile user can create and edit a call with internal participants"
      },
      {
        "id": "websocket_reconnect_room_media_control_recovery",
        "path": "frontend-vue/tests/e2e/chat-activity-matrix.spec.js",
        "test_title": "websocket reconnect resyncs room snapshot, media security, and control state"
      }
    ]
  },
  "commands": {
    "frontend:e2e:ui-parity": {
      "kind": "npm_script",
      "working_directory": "frontend-vue",
      "script": "test:e2e:ui-parity",
      "command": "npm run test:e2e:ui-parity",
      "paths": [
        "frontend-vue/tests/e2e/auth-navigation.spec.js",
        "frontend-vue/tests/e2e/login-backend-contract.spec.js",
        "frontend-vue/tests/e2e/ui-parity-journeys.spec.js",
        "frontend-vue/tests/e2e/responsive-call-management.spec.js",
        "frontend-vue/tests/e2e/shared-ui-surfaces.spec.js",
        "frontend-vue/tests/e2e/lobby-admission.spec.js",
        "frontend-vue/tests/e2e/chat-attachments.spec.js",
        "frontend-vue/tests/e2e/chat-archive.spec.js",
        "frontend-vue/tests/e2e/chat-activity-matrix.spec.js",
        "frontend-vue/tests/e2e/call-layout-strategies.spec.js"
      ]
    },
    "frontend:e2e:matrix": {
      "kind": "npm_script",
      "working_directory": "frontend-vue",
      "script": "test:e2e:matrix",
      "command": "npm run test:e2e:matrix",
      "paths": [
        "frontend-vue/tests/e2e/chat-attachments.spec.js",
        "frontend-vue/tests/e2e/chat-archive.spec.js",
        "frontend-vue/tests/e2e/call-layout-strategies.spec.js",
        "frontend-vue/tests/e2e/chat-activity-matrix.spec.js"
      ]
    },
    "frontend:contract:wlvc": {
      "kind": "npm_script",
      "working_directory": "frontend-vue",
      "script": "test:contract:wlvc",
      "command": "npm run test:contract:wlvc",
      "paths": [
        "frontend-vue/tests/contract/wlvc-wire-contract.mjs"
      ]
    },
    "backend:integration:http": {
      "kind": "shell",
      "working_directory": "backend-king-php",
      "command": "backend-king-php/tests/videochat-integration-matrix-http-contract.sh",
      "paths": [
        "backend-king-php/tests/videochat-integration-matrix-http-contract.sh"
      ]
    },
    "backend:integration:realtime": {
      "kind": "shell",
      "working_directory": "backend-king-php",
      "command": "backend-king-php/tests/videochat-integration-matrix-realtime-contract.sh",
      "paths": [
        "backend-king-php/tests/videochat-integration-matrix-realtime-contract.sh"
      ]
    },
    "backend:activity-layout": {
      "kind": "shell",
      "working_directory": "backend-king-php",
      "command": "backend-king-php/tests/realtime-activity-layout-contract.sh",
      "paths": [
        "backend-king-php/tests/realtime-activity-layout-contract.sh"
      ]
    },
    "backend:lobby-admission": {
      "kind": "shell",
      "working_directory": "backend-king-php",
      "command": "backend-king-php/tests/realtime-lobby-contract.sh",
      "paths": [
        "backend-king-php/tests/realtime-lobby-contract.sh",
        "backend-king-php/tests/realtime-lobby-db-sync-contract.sh"
      ]
    },
    "backend:chat-archive-attachments": {
      "kind": "shell",
      "working_directory": "backend-king-php",
      "command": "backend-king-php/tests/chat-attachment-contract.sh && backend-king-php/tests/chat-archive-contract.sh",
      "paths": [
        "backend-king-php/tests/chat-attachment-contract.sh",
        "backend-king-php/tests/chat-archive-contract.sh"
      ]
    },
    "backend:wlvc-wire": {
      "kind": "shell",
      "working_directory": "backend-king-php",
      "command": "backend-king-php/tests/wlvc-wire-contract.sh",
      "paths": [
        "backend-king-php/tests/wlvc-wire-contract.sh"
      ]
    }
  },
  "slices": [
    {
      "id": "auth_session_route_guards",
      "status": "covered",
      "readiness_refs": ["Z5 auth store", "Z5 role guards", "Z6 login journey"],
      "acceptance": [
        "Unauthenticated routes redirect to login.",
        "Authenticated admin/user sessions route to their role-safe landing pages.",
        "Call-goodbye is account-aware and does not leak guest-only exit UI to logged-in users."
      ],
      "checks": [
        {
          "command_id": "frontend:e2e:ui-parity",
          "paths": [
            "frontend-vue/tests/e2e/auth-navigation.spec.js",
            "frontend-vue/tests/e2e/login-backend-contract.spec.js"
          ]
        },
        {
          "command_id": "backend:integration:http",
          "paths": ["backend-king-php/tests/videochat-integration-matrix-http-contract.sh"]
        }
      ]
    },
    {
