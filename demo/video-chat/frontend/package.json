    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.5",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
