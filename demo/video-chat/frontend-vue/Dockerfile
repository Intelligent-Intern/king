FROM node:22-alpine

RUN apk add --no-cache \
    ca-certificates \
    chromium \
    freetype \
    harfbuzz \
    nss \
    ttf-freefont \
    && if [ ! -x /usr/bin/chromium-browser ] && [ -x /usr/bin/chromium ]; then ln -s /usr/bin/chromium /usr/bin/chromium-browser; fi

ARG VITE_VIDEOCHAT_BACKEND_ORIGIN=""
ARG VITE_VIDEOCHAT_BACKEND_PORT="18080"
ARG VITE_VIDEOCHAT_WS_ORIGIN=""
ARG VITE_VIDEOCHAT_WS_PORT=""
ARG VITE_VIDEOCHAT_SFU_ORIGIN=""
ARG VITE_VIDEOCHAT_SFU_PORT=""
ARG VITE_VIDEOCHAT_ALLOW_INSECURE_WS=""
ARG VITE_VIDEOCHAT_ICE_SERVERS=""
ARG VITE_VIDEOCHAT_ENABLE_SFU=""
ARG VITE_VIDEOCHAT_ENABLE_MEDIAPIPE=""
ARG VITE_VIDEOCHAT_ENABLE_TFJS=""
ARG VITE_VIDEOCHAT_ENABLE_REACTIVE_MEDIA_PIPELINE=""
ARG VITE_VIDEOCHAT_CDN_ORIGIN=""
ARG VIDEOCHAT_ASSET_VERSION=""
ARG VIDEOCHAT_PRODUCTION_SOURCEMAPS=""
ENV VITE_VIDEOCHAT_BACKEND_ORIGIN="${VITE_VIDEOCHAT_BACKEND_ORIGIN}"
ENV VITE_VIDEOCHAT_BACKEND_PORT="${VITE_VIDEOCHAT_BACKEND_PORT}"
ENV VITE_VIDEOCHAT_WS_ORIGIN="${VITE_VIDEOCHAT_WS_ORIGIN}"
ENV VITE_VIDEOCHAT_WS_PORT="${VITE_VIDEOCHAT_WS_PORT}"
ENV VITE_VIDEOCHAT_SFU_ORIGIN="${VITE_VIDEOCHAT_SFU_ORIGIN}"
ENV VITE_VIDEOCHAT_SFU_PORT="${VITE_VIDEOCHAT_SFU_PORT}"
ENV VITE_VIDEOCHAT_ALLOW_INSECURE_WS="${VITE_VIDEOCHAT_ALLOW_INSECURE_WS}"
ENV VITE_VIDEOCHAT_ICE_SERVERS="${VITE_VIDEOCHAT_ICE_SERVERS}"
ENV VITE_VIDEOCHAT_ENABLE_SFU="${VITE_VIDEOCHAT_ENABLE_SFU}"
ENV VITE_VIDEOCHAT_ENABLE_MEDIAPIPE="${VITE_VIDEOCHAT_ENABLE_MEDIAPIPE}"
ENV VITE_VIDEOCHAT_ENABLE_TFJS="${VITE_VIDEOCHAT_ENABLE_TFJS}"
ENV VITE_VIDEOCHAT_ENABLE_REACTIVE_MEDIA_PIPELINE="${VITE_VIDEOCHAT_ENABLE_REACTIVE_MEDIA_PIPELINE}"
ENV VITE_VIDEOCHAT_CDN_ORIGIN="${VITE_VIDEOCHAT_CDN_ORIGIN}"
ENV VIDEOCHAT_ASSET_VERSION="${VIDEOCHAT_ASSET_VERSION}"
ENV VIDEOCHAT_PRODUCTION_SOURCEMAPS="${VIDEOCHAT_PRODUCTION_SOURCEMAPS}"
ENV PLAYWRIGHT_BROWSERS_PATH=0
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

WORKDIR /app
COPY demo/video-chat/frontend-vue/package.json demo/video-chat/frontend-vue/package-lock.json ./
RUN npm ci

# Copy the rest of the files
COPY demo/video-chat/frontend-vue/ ./
COPY packages/iibin/dist/ /packages/iibin/dist/
RUN npm run build

# Vite's default dev port
EXPOSE 5174
# need to do npm install first outside. TODO: add that as part of the build for production image
# Default command (can be overridden by compose)
CMD ["npm", "run", "dev"]
