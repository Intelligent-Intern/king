FROM node:20-alpine AS build
WORKDIR /repo/demo/video-chat

ARG IIBIN_SOURCE=file:../../packages/iibin

COPY . /repo
RUN npm pkg set "dependencies.@intelligentintern/iibin=${IIBIN_SOURCE}" \
  && npm install --no-package-lock \
  && npm run build

FROM nginx:1.27-alpine
COPY demo/video-chat/nginx.video-chat.conf /etc/nginx/conf.d/default.conf
COPY --from=build /repo/demo/video-chat/dist /usr/share/nginx/html
EXPOSE 80
