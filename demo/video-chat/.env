# Default video-chat v1 stack endpoints.
#
# Keep machine-specific overrides in .env.local. Use scripts/compose-v1.sh so
# .env.local is loaded after this file.

VIDEOCHAT_V1_PUBLIC_SCHEME=http
VIDEOCHAT_V1_PUBLIC_HOST=127.0.0.1

VIDEOCHAT_V1_BACKEND_PORT=18080
VIDEOCHAT_V1_BACKEND_WS_PORT=18081
VIDEOCHAT_V1_BACKEND_SFU_PORT=18082
VIDEOCHAT_V1_FRONTEND_PORT=5176

# Set this to true for plain ws:// access from a non-loopback LAN host.
VIDEOCHAT_V1_ALLOW_INSECURE_WS=

# Optional: force the experimental WLVC/SFU video path in the frontend build.
# Leave empty to prefer native WebRTC for full audio/video fanout.
VITE_VIDEOCHAT_ENABLE_SFU=
