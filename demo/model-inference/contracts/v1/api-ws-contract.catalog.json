{
  "catalog_version": "v1.0.0",
  "catalog_name": "king-model-inference-api-ws",
  "catalog_scope": "king-model-inference demo, M-batch",
  "catalog_discipline": "every HTTP endpoint and every WS event exposed by the backend must be listed here; a parity contract test fails when code and catalog drift. Entries grow per sprint leaf as their module lands.",
  "api": {
    "runtime_health": {
      "method": "GET",
      "paths": ["/health", "/api/runtime"],
      "introduced_by": "M-1",
      "envelope": {
        "service": "model-inference-backend-king-php",
        "app": {"name": "string", "version": "string", "environment": "string"},
        "runtime": {
          "king_version": "string",
          "transport": "king_http1_server_listen_once",
          "ws_path": "string",
          "health": {
            "module_status": "string",
            "system_status": "string",
            "build": "string|null",
            "module_version": "string|null",
            "active_runtime_count": "int"
          }
        },
        "database": {"status": "string", "schema_version": "int", "path": "string"},
        "node": {"node_id": "string", "role": "inference-serving"},
        "status": "ok",
        "time": "rfc3339"
      }
    },
    "bootstrap": {
      "method": "GET",
      "paths": ["/", "/api/bootstrap"],
      "introduced_by": "M-1",
      "envelope": {
        "service": "model-inference-backend-king-php",
        "status": "bootstrapped",
        "message": "string",
        "ws_path": "string",
        "runtime_endpoint": "/api/runtime",
        "version_endpoint": "/api/version",
        "time": "rfc3339"
      }
    },
    "version": {
      "method": "GET",
      "paths": ["/api/version"],
      "introduced_by": "M-1",
      "envelope": {
        "service": "string",
        "app": {"name": "string", "version": "string", "environment": "string"},
        "runtime": {"king_version": "string", "build": "string|null", "module_version": "string|null"},
        "time": "rfc3339"
      }
    },
    "node_profile": {
      "method": "GET",
      "paths": ["/api/node/profile"],
      "introduced_by": "M-4",
      "envelope_contract": "demo/model-inference/contracts/v1/node-profile.contract.json",
      "envelope": {
        "node_id": "string",
        "king_version": "string",
        "platform": {"os": "darwin|linux|other", "arch": "string", "kernel": "string"},
        "cpu": {"logical_count": "int", "physical_count": "int", "brand": "string"},
        "memory": {"total_bytes": "int", "available_bytes": "int", "page_size": "int"},
        "gpu": {"present": "bool", "kind": "none|metal|cuda|rocm|other", "device_count": "int", "vram_total_bytes": "int", "vram_free_bytes": "int"},
        "capabilities": {"loadable_models": "array<string>", "max_context_tokens": "int", "supports_streaming": "bool", "supports_quantizations": "array<string>"},
        "service": {"service_type": "king.inference.v1", "health_url": "string", "status": "ready|draining|starting|error"},
        "published_at": "rfc3339"
      }
    },
    "models_list": {
      "method": "GET",
      "paths": ["/api/models"],
      "introduced_by": "M-5",
      "envelope_contract": "demo/model-inference/contracts/v1/model-registry-entry.contract.json",
      "envelope": {
        "status": "ok",
        "items": "array<model-registry-entry>",
        "count": "int",
        "time": "rfc3339"
      }
    },
    "models_create": {
      "method": "POST",
      "paths": ["/api/models"],
      "introduced_by": "M-5",
      "content_type": "application/octet-stream",
      "body": "raw GGUF bytes; metadata in X-Model-* request headers",
      "envelope_contract": "demo/model-inference/contracts/v1/model-registry-entry.contract.json",
      "envelope": {
        "status": "created",
        "model": "model-registry-entry",
        "time": "rfc3339"
      }
    },
    "model_get": {
      "method": "GET",
      "paths": ["/api/models/{model_id}"],
      "introduced_by": "M-5",
      "envelope_contract": "demo/model-inference/contracts/v1/model-registry-entry.contract.json",
      "envelope": {
        "status": "ok",
        "model": "model-registry-entry",
        "time": "rfc3339"
      }
    },
    "model_delete": {
      "method": "DELETE",
      "paths": ["/api/models/{model_id}"],
      "introduced_by": "M-5",
      "envelope": {
        "status": "deleted",
        "model_id": "string",
        "time": "rfc3339"
      }
    },
    "chat_ui": {
      "method": "GET",
      "paths": ["/ui", "/ui/"],
      "introduced_by": "M-11b",
      "content_type": "text/html; charset=utf-8",
      "scope": "Browser-visible single-file chat client. Static HTML+CSS+JS; decodes TokenFrame binaries client-side and streams deltas into the live assistant bubble. See backend-king-php/public/chat.html."
    },
    "telemetry_recent": {
      "method": "GET",
      "paths": ["/api/telemetry/inference/recent"],
      "introduced_by": "M-12",
      "envelope": {
        "status": "ok",
        "items": "array<InferenceMetricsEntry>",
        "count": "int",
        "capacity": "int",
        "time": "rfc3339"
      },
      "item_shape": {
        "request_id": "string",
        "session_id": "string",
        "transport": "http|ws",
        "model_id": "string",
        "model_name": "string",
        "quantization": "string",
        "node_id": "string",
        "tokens_in": "int",
        "tokens_out": "int",
        "ttft_ms": "int",
        "duration_ms": "int",
        "tokens_per_second": "float",
        "vram_total_bytes": "int",
        "vram_free_bytes": "int",
        "gpu_kind": "none|metal|cuda|rocm|other",
        "recorded_at": "rfc3339"
      }
    },
    "documents_list": {
      "method": "GET",
      "paths": ["/api/documents"],
      "introduced_by": "R-5",
      "envelope": {
        "status": "ok",
        "items": "array<document>",
        "count": "int",
        "time": "rfc3339"
      }
    },
    "documents_create": {
      "method": "POST",
      "paths": ["/api/documents"],
      "introduced_by": "R-5",
      "content_type": "text/plain",
      "body": "raw plain text document",
      "envelope": {
        "status": "created",
        "document": {
          "document_id": "string",
          "byte_length": "int",
          "sha256_hex": "string",
          "content_type": "text/plain",
          "ingested_at": "rfc3339"
        },
        "time": "rfc3339"
      }
    },
    "document_get": {
      "method": "GET",
      "paths": ["/api/documents/{document_id}"],
      "introduced_by": "R-5",
      "envelope": {
        "status": "ok",
        "document": {
          "document_id": "string",
          "byte_length": "int",
          "sha256_hex": "string",
          "content_type": "text/plain",
          "ingested_at": "rfc3339"
        },
        "time": "rfc3339"
      }
    },
    "document_chunks": {
      "method": "GET",
      "paths": ["/api/documents/{document_id}/chunks"],
      "introduced_by": "R-7",
      "envelope": {
        "status": "ok",
        "document_id": "string",
        "items": "array<chunk-envelope>",
        "count": "int",
        "time": "rfc3339"
      }
    },
    "embed": {
      "method": "POST",
      "paths": ["/api/embed"],
      "introduced_by": "R-4",
      "content_type": "application/json",
      "request_contract": "demo/model-inference/contracts/v1/embedding-request.contract.json",
      "envelope": {
        "status": "ok",
        "request_id": "string",
        "embeddings": "array<array<float>>",
        "dimensions": "int",
        "model": {"model_id": "string", "model_name": "string", "quantization": "string"},
        "tokens_used": "int",
        "duration_ms": "int",
        "time": "rfc3339"
      }
    },
    "rag": {
      "method": "POST",
      "paths": ["/api/rag"],
      "introduced_by": "R-11",
      "content_type": "application/json",
      "envelope": {
        "status": "ok",
        "request_id": "string",
        "completion": "string",
        "context": {"chunks_used": "int", "results": "array", "vectors_scanned": "int"},
        "model": {"chat": {"model_id": "string", "model_name": "string", "quantization": "string"}, "embedding": {"model_id": "string", "model_name": "string", "quantization": "string"}},
        "timing": {"embedding_ms": "int", "retrieval_ms": "int", "inference_ms": "int", "total_ms": "int"},
        "inference": {"tokens_in": "int", "tokens_out": "int", "ttft_ms": "int", "duration_ms": "int"},
        "time": "rfc3339"
      }
    },
    "telemetry_rag_recent": {
      "method": "GET",
      "paths": ["/api/telemetry/rag/recent"],
      "introduced_by": "R-12",
      "envelope": {
        "status": "ok",
        "items": "array<RagMetricsEntry>",
        "count": "int",
        "capacity": "int",
        "time": "rfc3339"
      }
    },
    "retrieve": {
      "method": "POST",
      "paths": ["/api/retrieve"],
      "introduced_by": "R-10",
      "content_type": "application/json",
      "request_contract": "demo/model-inference/contracts/v1/retrieval-request.contract.json",
      "envelope": {
        "status": "ok",
        "request_id": "string",
        "results": "array<{chunk_id, document_id, text, score, vector_id}>",
        "result_count": "int",
        "search_strategy": "brute_force_cosine",
        "embedding_ms": "int",
        "search_ms": "int",
        "vectors_scanned": "int",
        "time": "rfc3339"
      }
    },
    "infer_http": {
      "method": "POST",
      "paths": ["/api/infer"],
      "introduced_by": "M-10",
      "content_type": "application/json",
      "request_contract": "demo/model-inference/contracts/v1/inference-request.contract.json",
      "envelope": {
        "status": "ok",
        "request_id": "string",
        "session_id": "string",
        "model": {"model_id": "string", "model_name": "string", "quantization": "string"},
        "completion": {
          "text": "string",
          "tokens_in": "int",
          "tokens_out": "int",
          "ttft_ms": "int",
          "duration_ms": "int",
          "request_wall_ms": "int",
          "stop": {"type": "string", "word": "string", "truncated": "bool"}
        },
        "worker": {"pid": "int", "port": "int", "gguf_path": "string"},
        "time": "rfc3339"
      }
    },
    "transcripts_get": {
      "method": "GET",
      "paths": ["/api/transcripts/{request_id}"],
      "introduced_by": "M-16",
      "envelope": {
        "status": "ok",
        "transcript": {
          "request_id": "string",
          "session_id": "string",
          "transport": "http|ws",
          "model": {"model_id": "string", "model_name": "string", "quantization": "string"},
          "prompt": "string",
          "system": "string|null",
          "sampling": "object",
          "completion": "object",
          "recorded_at": "rfc3339"
        },
        "time": "rfc3339"
      }
    },
    "route_diagnostic": {
      "method": "GET",
      "paths": ["/api/route"],
      "introduced_by": "M-14",
      "scope": "Diagnostic endpoint exposing the current Semantic-DNS routing resolution for a given model selector. Accepts optional query params: model_name, quantization, min_free_vram_bytes.",
      "envelope": {
        "status": "ok",
        "routing": {
          "role": "inference",
          "primary": "node|null",
          "failover": "list<node>",
          "candidates": "list<node>",
          "resolved_at": "rfc3339",
          "source": "semantic_dns|unavailable"
        },
        "criteria": "object|null",
        "time": "rfc3339"
      }
    },
    "discover": {
      "method": "POST",
      "paths": ["/api/discover"],
      "introduced_by": "S-4",
      "content_type": "application/json",
      "scope": "Retrieval-backed service discovery over registered service_embeddings. Supports mode=keyword|semantic|hybrid with brute-force cosine + BM25 fusion. Returns ranked services for a natural-language query.",
      "envelope_contract": "demo/model-inference/contracts/v1/service-descriptor.contract.json",
      "envelope": {
        "status": "ok",
        "request_id": "string",
        "mode": "keyword|semantic|hybrid",
        "results": "array<{service_id, service_type, vector_id, dimensions, score, descriptor}>",
        "result_count": "int",
        "candidates_scanned": "int",
        "search_strategy": "brute_force_cosine|hybrid_cosine_bm25|keyword_bm25",
        "embedding_ms": "int",
        "search_ms": "int",
        "alpha": "float?",
        "bm25_k1": "float?",
        "bm25_b": "float?",
        "model": {"model_id": "string", "model_name": "string", "quantization": "string"},
        "time": "rfc3339"
      }
    },
    "tools_discover": {
      "method": "POST",
      "paths": ["/api/tools/discover"],
      "introduced_by": "S-9",
      "content_type": "application/json",
      "scope": "Retrieval-backed tool discovery over registered tool_embeddings. Returns ranked tools including their durable mcp_target for subsequent invocation via king_mcp_request.",
      "envelope_contract": "demo/model-inference/contracts/v1/tool-descriptor.contract.json",
      "envelope": {
        "status": "ok",
        "request_id": "string",
        "mode": "keyword|semantic|hybrid",
        "results": "array<{tool_id, vector_id, dimensions, mcp_target, score, descriptor}>",
        "result_count": "int",
        "candidates_scanned": "int",
        "search_strategy": "brute_force_cosine|hybrid_cosine_bm25|keyword_bm25",
        "embedding_ms": "int",
        "search_ms": "int",
        "alpha": "float?",
        "bm25_k1": "float?",
        "bm25_b": "float?",
        "model": {"model_id": "string", "model_name": "string", "quantization": "string"},
        "time": "rfc3339"
      }
    },
    "tools_pick": {
      "method": "POST",
      "paths": ["/api/tools/pick"],
      "introduced_by": "S-10",
      "content_type": "application/json",
      "scope": "Thin wrapper around /api/tools/discover that returns the single highest-scoring mcp_target, fail-closed with no_semantic_match when no tool scores above min_score.",
      "envelope_contract": "demo/model-inference/contracts/v1/tool-descriptor.contract.json",
      "envelope": {
        "status": "ok",
        "request_id": "string",
        "tool_id": "string",
        "mcp_target": {"host": "string", "port": "int", "service": "string", "method": "string"},
        "score": "float",
        "mode": "semantic|hybrid",
        "embedding_ms": "int",
        "search_ms": "int",
        "candidates_scanned": "int",
        "time": "rfc3339"
      }
    },
    "telemetry_discovery_recent": {
      "method": "GET",
      "paths": ["/api/telemetry/discovery/recent"],
      "introduced_by": "S-11",
      "envelope": {
        "status": "ok",
        "items": "array<DiscoveryMetricsEntry>",
        "count": "int",
        "capacity": "int",
        "time": "rfc3339"
      },
      "item_shape": {
        "request_id": "string",
        "mode": "keyword|semantic|hybrid",
        "embedding_ms": "int",
        "search_ms": "int",
        "total_ms": "int",
        "candidates_scanned": "int",
        "query_length": "int",
        "service_type": "string",
        "top_k": "int",
        "min_score": "float",
        "alpha": "float",
        "recorded_at": "rfc3339"
      }
    },
    "conversation_messages_list": {
      "method": "GET",
      "paths": ["/api/conversations/{session_id}/messages"],
      "introduced_by": "C-batch (V.8)",
      "envelope_contract": "demo/model-inference/contracts/v1/conversation-message.contract.json",
      "scope": "Replay the persisted transcript for a session so the chat UI can rehydrate state.history on page reload. Closes readiness tracker bullet V.8."
    },
    "conversation_meta_get": {
      "method": "GET",
      "paths": ["/api/conversations/{session_id}"],
      "introduced_by": "C-batch (V.8)",
      "envelope": {
        "status": "ok",
        "session_id": "string",
        "found": "bool",
        "meta": "{created_at, updated_at, turn_count, last_request_id, last_model_name, last_model_quantization}|null",
        "time": "rfc3339"
      }
    },
    "conversation_delete": {
      "method": "DELETE",
      "paths": ["/api/conversations/{session_id}"],
      "introduced_by": "C-batch (V.8)",
      "envelope": {
        "status": "ok",
        "session_id": "string",
        "deleted_message_count": "int",
        "time": "rfc3339"
      }
    },
    "conversation_list_me": {
      "method": "GET",
      "paths": ["/api/conversations/me"],
      "introduced_by": "A-batch (AB.3)",
      "auth": "Bearer token required",
      "scope": "Lists conversations owned by the authenticated user (conversations.user_ref = user.id). Ordered by updated_at DESC, capped at 100. Anonymous conversations (user_ref NULL) never appear here.",
      "envelope": {
        "status": "ok",
        "user": "user-session.contract.json#user",
        "conversations": "array<{session_id, created_at, updated_at, turn_count, last_request_id, last_model_name, last_model_quantization, user_ref}>",
        "count": "int",
        "time": "rfc3339"
      }
    },
    "auth_login": {
      "method": "POST",
      "paths": ["/api/auth/login"],
      "introduced_by": "A-batch (AB.1, AB.2)",
      "content_type": "application/json",
      "request_contract": "demo/model-inference/contracts/v1/auth-request.contract.json",
      "envelope": {
        "status": "ok",
        "session": "user-session.contract.json#session",
        "user": "user-session.contract.json#user",
        "time": "rfc3339"
      }
    },
    "auth_logout": {
      "method": "POST",
      "paths": ["/api/auth/logout"],
      "introduced_by": "A-batch (AB.2)",
      "envelope": {
        "status": "ok",
        "revocation_state": "revoked|already_revoked",
        "revoked_at": "rfc3339|null",
        "time": "rfc3339"
      }
    },
    "auth_whoami": {
      "method": "GET",
      "paths": ["/api/auth/whoami"],
      "introduced_by": "A-batch (AB.2)",
      "envelope": {
        "status": "ok",
        "user": "user-session.contract.json#user",
        "session": "user-session.contract.json#session",
        "time": "rfc3339"
      }
    },
    "login_ui": {
      "method": "GET",
      "paths": ["/ui/login", "/ui/login/"],
      "introduced_by": "A-batch (A-7c)",
      "content_type": "text/html; charset=utf-8",
      "scope": "Dedicated static-HTML login page under the /ui/* browser-UI namespace. Served by module_ui (shared static-file helper). Prefill demo creds, POSTs to /api/auth/login, then window.location = /ui on success. Anonymous continuation via a 'Continue as guest' button."
    }
  },
  "ws": {
    "path": "/ws",
    "introduced_by": "M-11",
    "handshake": {
      "method": "GET",
      "required_headers": {
        "Upgrade": "websocket",
        "Connection": "Upgrade",
        "Sec-WebSocket-Key": "base64 nonce",
        "Sec-WebSocket-Version": "13"
      }
    },
    "client_events": {
      "infer.start": {
        "direction": "client->server",
        "frame_type": "text",
        "body_shape": {"event": "infer.start", "payload": "inference-request envelope with stream=true"},
        "request_contract": "demo/model-inference/contracts/v1/inference-request.contract.json"
      }
    },
    "server_events": {
      "infer.token": {
        "direction": "server->client",
        "frame_type": "binary",
        "body_contract": "demo/model-inference/contracts/v1/token-frame.contract.json",
        "frame_type_value": "delta"
      },
      "infer.end": {
        "direction": "server->client",
        "frame_type": "binary",
        "body_contract": "demo/model-inference/contracts/v1/token-frame.contract.json",
        "frame_type_value": "end"
      },
      "infer.error": {
        "direction": "server->client",
        "frame_type": "binary",
        "body_contract": "demo/model-inference/contracts/v1/token-frame.contract.json",
        "frame_type_value": "error"
      }
    }
  },
  "errors": {
    "envelope": {
      "status": "error",
      "error": {"code": "string", "message": "string", "details": "object?"},
      "time": "rfc3339"
    },
    "codes": [
      "extension_not_loaded",
      "internal_server_error",
      "not_implemented",
      "method_not_allowed",
      "invalid_request_envelope",
      "model_not_found",
      "model_artifact_write_failed",
      "model_artifact_too_large",
      "model_registry_conflict",
      "model_fit_unavailable",
      "worker_unavailable",
      "transcript_not_found",
      "routing_no_candidate",
      "document_not_found",
      "document_too_large",
      "invalid_service_descriptor",
      "invalid_tool_descriptor",
      "embedding_worker_unavailable_discovery",
      "no_semantic_match",
      "invalid_credentials",
      "session_expired",
      "session_revoked",
      "ownership_denied"
    ]
  },
  "planned_surfaces_target_shape": {
    "note": "Entries below are target-shape only, added to the live api/ws/errors sections as their leaves land. Listed here so readers see the full intended v1 surface without a parity-test false negative.",
    "api": {
      "worker_status":    {"method": "GET",  "paths": ["/api/worker"],                       "introduced_by": "M-7"}
    },
    "ws": {
      "infer.cancel": {"direction": "client->server", "body": "json",                    "introduced_by": "future"}
    },
    "error_codes": [
      "invalid_request_envelope",
      "model_not_found",
      "model_fit_unavailable",
      "worker_unavailable",
      "worker_draining",
      "routing_no_candidate",
      "transcript_not_found",
      "auth_failed",
      "rbac_forbidden"
    ]
  }
}
