question_index=5 kind=coding status=PASS
prompt=Explain Big O of binary search and show a short JavaScript example.
provenance=source=king_voltron_handler tool=voltron.execute_model_block backend=local step=voltron.execute_block.output_head
response=Binary search runs in O(log n) time and O(1) extra space.

function binarySearch(arr, target) {
  let lo = 0, hi = arr.length - 1;
  while (lo <= hi) {
    const mid = (lo + hi) >> 1;
    if (arr[mid] === target) return mid;
    if (arr[mid] < target) lo = mid + 1;
    else hi = mid - 1;
  }
  return -1;
}

