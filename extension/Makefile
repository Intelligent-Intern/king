$(phplibdir)/king.la: ./king.la
	$(LIBTOOL) --tag=CC --mode=install cp ./king.la $(phplibdir)

./king.la: $(shared_objects_king) $(KING_SHARED_DEPENDENCIES)
	$(LIBTOOL) --tag=CC --mode=link $(CC) -shared $(COMMON_FLAGS) $(CFLAGS_CLEAN) $(EXTRA_CFLAGS) $(LDFLAGS)  -o $@ -export-dynamic -avoid-version -prefer-pic -module -rpath $(phplibdir) $(EXTRA_LDFLAGS) $(shared_objects_king) $(KING_SHARED_LIBADD)

